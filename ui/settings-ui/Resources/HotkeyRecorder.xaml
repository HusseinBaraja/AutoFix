<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="SettingsTheme.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- Keycap pill tokens -->
    <SolidColorBrush x:Key="KeycapBackgroundBrush" Color="#F3F4F8" />
    <SolidColorBrush x:Key="KeycapBorderBrush" Color="#C5CEDE" />
    <SolidColorBrush x:Key="KeycapTextBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="KeycapSeparatorBrush" Color="#94A3B8" />

    <!-- Conflict tokens -->
    <SolidColorBrush x:Key="HotkeyConflictBrush" Color="#DC6803" />
    <SolidColorBrush x:Key="HotkeyConflictBackgroundBrush" Color="#FFF8E6" />

    <!-- Recording state tokens -->
    <SolidColorBrush x:Key="RecordingPulseBrush" Color="#6F54E8" />
    <SolidColorBrush x:Key="RecordingBackgroundBrush" Color="#F8F7FF" />
    <SolidColorBrush x:Key="RecordingTextBrush" Color="#5D6B82" />

    <!-- Action button tokens -->
    <SolidColorBrush x:Key="HotkeyClearBrush" Color="#94A3B8" />
    <SolidColorBrush x:Key="HotkeyClearHoverBrush" Color="#64748B" />
    <SolidColorBrush x:Key="HotkeyDefaultLinkBrush" Color="#6F54E8" />

    <DropShadowEffect x:Key="KeycapShadow"
                      BlurRadius="2"
                      ShadowDepth="1"
                      Opacity="0.12"
                      Direction="270"
                      Color="#2D3A55" />

    <!-- Individual keycap pill style -->
    <Style x:Key="KeycapPill" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource KeycapBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource KeycapBorderBrush}" />
        <Setter Property="BorderThickness" Value="1,1,1,2" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,5,10,5" />
        <Setter Property="Margin" Value="0,0,2,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Effect" Value="{StaticResource KeycapShadow}" />
    </Style>

    <!-- Clear (x) button -->
    <Style x:Key="HotkeyClearButton" TargetType="Button">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Margin" Value="4,0,0,0" />
        <Setter Property="ToolTip" Value="Clear shortcut" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Ellipse x:Name="HoverBg"
                                 Fill="Transparent"
                                 Width="24"
                                 Height="24" />
                        <TextBlock x:Name="Icon"
                                   Text="&#xD7;"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource HotkeyClearBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="0,-2,0,0" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HoverBg" Property="Fill" Value="#F1F5F9" />
                            <Setter TargetName="Icon" Property="Foreground" Value="{StaticResource HotkeyClearHoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Reset to default link -->
    <Style x:Key="HotkeyDefaultLink" TargetType="Button">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Margin" Value="4,0,0,0" />
        <Setter Property="ToolTip" Value="Reset to default shortcut" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <TextBlock x:Name="LinkText"
                                   Text="Default"
                                   FontSize="12"
                                   FontWeight="Medium"
                                   Foreground="{StaticResource HotkeyDefaultLinkBrush}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#F0EDFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Conflict warning banner -->
    <Style x:Key="HotkeyConflictWarning" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource HotkeyConflictBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource HotkeyConflictBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="Margin" Value="0,6,0,0" />
    </Style>

    <!-- Hotkey recorder well (idle state container) -->
    <Style x:Key="HotkeyRecorderWell" TargetType="Border">
        <Setter Property="Background" Value="#FCFDFE" />
        <Setter Property="BorderBrush" Value="#DCE2EE" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource SettingsCornerRadius}" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="MinHeight" Value="44" />
    </Style>

</ResourceDictionary>
